# ==========================================
# Smart Agri-Mesh v2 - .gitignore
# ==========================================

# ------------------------------------------
# 1. OS & Editor / IDE (Hệ điều hành & Trình soạn thảo)
# ------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------
# 2. Firmware (STM32 & ESP32)
# ------------------------------------------
# STM32CubeIDE / Keil
firmware/**/Debug/
firmware/**/Release/
*.o
*.d
*.elf
*.hex
*.bin
*.map
.mxproject

# ESP-IDF / PlatformIO / Arduino
firmware/**/build/
firmware/**/.pio/
firmware/**/sdkconfig
*.ino.bin
*.ino.elf

# ------------------------------------------
# 3. Hardware (PCB Design - KiCad / Altium)
# ------------------------------------------
# KiCad backups and temporary files
hardware/**/*.bak
hardware/**/*-bak
hardware/**/*.bck
hardware/**/*.kicad_pcb-bak

# Altium temporary files
hardware/**/History/
hardware/**/__Previews/
hardware/**/*.PrjPcbStructure

# ------------------------------------------
# 4. Mechanical (SolidWorks)
# ------------------------------------------
# Lock/Temporary files generated by SolidWorks while a file is open
mechanical/**/~$*.sldprt
mechanical/**/~$*.sldasm
mechanical/**/~$*.slddrw

# Backup files
mechanical/**/*.bak
mechanical/**/Backup*/

# ------------------------------------------
# 5. Server (Node.js / Python)
# ------------------------------------------
server/node_modules/
server/npm-debug.log*
server/yarn-error.log*
server/build/
server/dist/

# Python (Nếu backend có dùng Python)
server/__pycache__/
server/*.py[cod]
server/venv/
server/.env/

# KHÔNG đẩy file biến môi trường chứa API Key/Password lên Git
server/.env

# ------------------------------------------
# 6. Web App (ReactJS / VueJS)
# ------------------------------------------
web-app/node_modules/
web-app/build/
web-app/dist/
web-app/out/
web-app/.env
web-app/.env.local
web-app/.env.development.local

# ------------------------------------------
# 7. Mobile App (Flutter / React Native)
# ------------------------------------------
# Chung
mobile-app/node_modules/
mobile-app/.env

# Flutter
mobile-app/build/
mobile-app/.dart_tool/
mobile-app/.flutter-plugins
mobile-app/.flutter-plugins-dependencies
mobile-app/.pub-cache/
mobile-app/.packages

# iOS / Android (React Native & Flutter)
mobile-app/ios/Pods/
mobile-app/ios/.symlinks/
mobile-app/android/.gradle/
mobile-app/android/app/build/

# ------------------------------------------
# 8. AI Models & Data (Edge Impulse)
# ------------------------------------------
# Bỏ qua các file dataset quá nặng hoặc file nén tạm
ai-models/datasets/
ai-models/**/*.zip
ai-models/temp_builds/

# ------------------------------------------
# 9. Miscellaneous (Khác)
# ------------------------------------------
*.log
*.tmp
*.temp